library(vegan)
library(readxl)
data=data.frame(read_excel("all10_samples.xlsx"),row.names = 1)
data=data[,6:10]

mydata=t(data)

shannon=diversity(mydata,index="shannon")
shannon

shannon_df=data.frame(
  Sample=names(shannon),
  value=shannon,
  Metric="Shannon")

library(ggplot2)
shannon=ggplot(shannon_df, aes(x = Sample, y = Diversity)) +
  geom_point(size  = 4,
             color = "steelblue") +
  theme_classic()+
  labs(title="Shannon Diversity Index")


richness <- specnumber(t(data))
richness_df=data.frame(
  Sample=names(richness),
  value=richness,
  Metric="Richness")

combined_df=rbind(shannon_df,richness_df)

Richness=ggplot(richness_df, aes(x = Samples, y = Richness)) +
  geom_point(size  = 4,
             color = "steelblue") +
  theme_classic()+
  labs(title="Richness")

